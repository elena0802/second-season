# Resend — newsletter email delivery
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender in Resend (must match your domain)
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME="Second Season"

# Admin inbox for test sends (Phase 11D+)
ADMIN_EMAIL=

# Required for POST /api/newsletter/send-test (x-newsletter-admin-secret header)
NEWSLETTER_ADMIN_SECRET=
